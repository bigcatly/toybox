page {
  min-height: 100vh;
  color: #3a2112;
  background: radial-gradient(circle at 14% 6%, #fff5d7 0, rgba(255, 245, 215, 0) 260rpx), linear-gradient(180deg, #fffaf0 0%, #fff8ea 55%, #fffaf4 100%);
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, Arial, "PingFang SC", "Microsoft YaHei", sans-serif;
}

view,
text,
input,
textarea,
button,
image {
  box-sizing: border-box;
}

button {
  margin: 0;
  padding: 0;
  line-height: 1;
  border: 0;
  background: transparent;
}

button::after {
  border: 0;
}

image {
  display: block;
}

.app-page {
  position: relative;
  min-height: 100vh;
  padding: 28rpx 26rpx 156rpx;
  overflow: hidden;
}

.app-page::before {
  position: fixed;
  left: 0;
  top: 0;
  z-index: -1;
  width: 100%;
  height: 100%;
  content: '';
  background:
    radial-gradient(circle at 82% 8%, rgba(255, 219, 129, 0.28), rgba(255, 219, 129, 0) 210rpx),
    radial-gradient(circle at 18% 78%, rgba(195, 231, 255, 0.22), rgba(195, 231, 255, 0) 260rpx);
}

.status-space {
  height: 54rpx;
}

.soft-card {
  border: 2rpx solid rgba(235, 184, 94, 0.42);
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.72);
  box-shadow: 0 14rpx 36rpx rgba(165, 107, 33, 0.12), inset 0 2rpx 0 rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(8px);
}

.glass-card {
  border: 2rpx solid rgba(255, 255, 255, 0.86);
  border-radius: 34rpx;
  background: rgba(255, 255, 255, 0.58);
  box-shadow: 0 18rpx 46rpx rgba(124, 84, 26, 0.12);
}

.round-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 76rpx;
  height: 76rpx;
  border: 2rpx solid rgba(239, 199, 129, 0.46);
  border-radius: 50%;
  color: #3b2111;
  font-size: 40rpx;
  font-weight: 900;
  background: rgba(255, 255, 255, 0.86);
  box-shadow: 0 10rpx 24rpx rgba(121, 78, 22, 0.1);
}

.primary-orange {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 86rpx;
  border-radius: 999rpx;
  color: #fff;
  font-size: 31rpx;
  font-weight: 900;
  letter-spacing: 1rpx;
  background: linear-gradient(180deg, #ffb23c 0%, #ff8619 52%, #ff7410 100%);
  box-shadow: 0 14rpx 0 #ee6410, 0 24rpx 38rpx rgba(247, 120, 20, 0.28);
}

.primary-orange:active,
.pressable:active {
  transform: scale(0.97);
  opacity: 0.94;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 26rpx 8rpx 18rpx;
}

.section-title {
  display: flex;
  align-items: center;
  gap: 10rpx;
  color: #321c0f;
  font-size: 32rpx;
  font-weight: 900;
}

.section-more {
  display: flex;
  align-items: center;
  gap: 8rpx;
  color: #998b7b;
  font-size: 24rpx;
}

.toy-img {
  width: 100%;
  height: 100%;
}

.mini-toy-card {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  min-height: 132rpx;
  border: 2rpx solid rgba(236, 213, 176, 0.72);
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.76);
  box-shadow: inset 0 2rpx 0 rgba(255,255,255,0.92), 0 8rpx 16rpx rgba(101, 72, 33, 0.06);
}

.mini-toy-card__img {
  width: 76rpx;
  height: 76rpx;
}

.mini-toy-card__name {
  margin-top: 8rpx;
  color: #2e2018;
  font-size: 23rpx;
  font-weight: 700;
  line-height: 1.1;
}

.toy-tabbar {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: 18rpx;
  z-index: 50;
  display: flex;
  align-items: center;
  justify-content: space-around;
  height: 118rpx;
  padding: 0 22rpx;
  border: 2rpx solid rgba(237, 213, 178, 0.62);
  border-radius: 38rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 18rpx 48rpx rgba(103, 76, 38, 0.16);
  backdrop-filter: blur(12px);
}

.toy-tabbar__item {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  width: 132rpx;
  height: 96rpx;
  color: #7c7c7c;
  font-size: 24rpx;
  font-weight: 700;
}

.toy-tabbar__icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 48rpx;
  height: 48rpx;
  margin-bottom: 6rpx;
  border-radius: 14rpx;
  color: #7f7f7f;
  font-size: 36rpx;
  font-weight: 900;
}

.toy-tabbar__item--active {
  color: #ff9518;
}

.toy-tabbar__item--active .toy-tabbar__icon {
  color: #fff;
  background: linear-gradient(180deg, #ffc445, #ff981b);
  box-shadow: 0 8rpx 18rpx rgba(255, 151, 25, 0.24);
}

.badge-pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 50rpx;
  padding: 0 22rpx;
  border: 2rpx solid rgba(237, 211, 166, 0.64);
  border-radius: 999rpx;
  color: #6e3d16;
  font-size: 25rpx;
  font-weight: 800;
  background: rgba(255, 255, 255, 0.78);
  box-shadow: 0 8rpx 18rpx rgba(123, 82, 34, 0.08);
}

.tone-green { background: linear-gradient(135deg, #edfff0, #d9f8dc); }
.tone-pink { background: linear-gradient(135deg, #fff2ee, #ffe2de); }
.tone-blue { background: linear-gradient(135deg, #f0fbff, #dcefff); }
.tone-purple { background: linear-gradient(135deg, #fff3ff, #f1e3ff); }
.tone-yellow { background: linear-gradient(135deg, #fff8dc, #ffe9a8); }
.tone-orange { background: linear-gradient(135deg, #fff1df, #ffd9ad); }
.tone-cream { background: linear-gradient(135deg, #fffdf8, #fff3df); }
