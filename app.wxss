page {
  min-height: 100vh;
  color: #2b221b;
  background: #fff7ea;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, Arial, "PingFang SC", "Microsoft YaHei", sans-serif;
}

view,
text,
input,
textarea,
button {
  box-sizing: border-box;
}

button {
  margin: 0;
  padding: 0;
  line-height: 1;
  border: 0;
  background: transparent;
}

button::after {
  border: 0;
}

.container {
  padding: 28rpx 28rpx 48rpx;
}

.card {
  border: 2rpx solid rgba(86, 54, 26, 0.08);
  border-radius: 36rpx;
  background: rgba(255, 255, 255, 0.82);
  box-shadow: 0 24rpx 60rpx rgba(103, 68, 34, 0.10);
}

.primary-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 92rpx;
  border-radius: 999rpx;
  color: #fff;
  font-size: 30rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #ff8a3d, #ff5c7a);
  box-shadow: 0 18rpx 36rpx rgba(255, 107, 87, 0.28);
}

.secondary-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 84rpx;
  border-radius: 999rpx;
  color: #7a4f26;
  font-size: 28rpx;
  font-weight: 700;
  background: #fff1d9;
}

.muted {
  color: #8c7765;
}
