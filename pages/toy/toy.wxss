.toy-page {
  padding-bottom: 60rpx;
}

.toy-hero {
  overflow: hidden;
  padding: 44rpx 34rpx;
  color: #fff;
}

.toy-hero__emoji {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 120rpx;
  height: 120rpx;
  border-radius: 34rpx;
  font-size: 70rpx;
  background: rgba(255, 255, 255, 0.26);
}

.toy-hero__name {
  margin-top: 28rpx;
  font-size: 48rpx;
  font-weight: 900;
}

.toy-hero__desc {
  margin-top: 14rpx;
  font-size: 28rpx;
  line-height: 1.55;
  opacity: 0.92;
}

.wood,
.wheel,
.breath,
.dice,
.bubble,
.fortune {
  margin-top: 26rpx;
  padding: 34rpx;
}

.wood {
  display: flex;
  align-items: center;
  flex-direction: column;
}

.wood__score {
  font-size: 84rpx;
  font-weight: 900;
}

.wood__label {
  color: #8c7765;
  font-size: 24rpx;
}

.wood__fish {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 320rpx;
  height: 320rpx;
  margin-top: 38rpx;
  border-radius: 50%;
  background: radial-gradient(circle at 35% 25%, #ffe8a3, #a7682c 70%);
  box-shadow: inset -16rpx -28rpx 42rpx rgba(89, 43, 12, 0.28), 0 24rpx 60rpx rgba(117, 68, 27, 0.24);
}

.wood__fish:active {
  transform: scale(0.96);
}

.wood__fish-core {
  font-size: 132rpx;
}

.wood__hint {
  margin-top: 26rpx;
  color: #8c7765;
  font-size: 26rpx;
}

.wood__hits {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 12rpx;
  min-height: 52rpx;
  margin: 26rpx 0;
}

.wood__hit {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  color: #8b633b;
  font-size: 22rpx;
  background: #fff1d9;
}

.wheel__stage {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 460rpx;
}

.wheel__pointer {
  position: absolute;
  top: 4rpx;
  z-index: 2;
  color: #ff5c7a;
  font-size: 52rpx;
}

.wheel__disc {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
  gap: 14rpx;
  width: 350rpx;
  height: 350rpx;
  padding: 56rpx;
  border-radius: 50%;
  background: conic-gradient(from 0deg, #ffd36b, #ff8a3d, #ff5c7a, #7f7cff, #80d0ff, #ffd36b);
  box-shadow: 0 24rpx 60rpx rgba(77, 68, 150, 0.2);
  transition: transform 1.5s cubic-bezier(0.12, 0.82, 0.18, 1);
}

.wheel__option {
  max-width: 120rpx;
  padding: 8rpx 12rpx;
  border-radius: 999rpx;
  color: #4a2c12;
  font-size: 20rpx;
  font-weight: 800;
  background: rgba(255, 255, 255, 0.76);
}

.result-box {
  margin-top: 24rpx;
  padding: 24rpx;
  border-radius: 28rpx;
  color: #7a3810;
  font-size: 30rpx;
  font-weight: 900;
  text-align: center;
  background: #fff1d9;
}

.option-editor {
  margin-top: 34rpx;
}

.option-editor__title,
.dice__history-title {
  margin-bottom: 18rpx;
  font-size: 28rpx;
  font-weight: 900;
}

.option-input-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.option-input {
  flex: 1;
  height: 82rpx;
  padding: 0 22rpx;
  border-radius: 24rpx;
  font-size: 26rpx;
  background: #fff7ea;
}

.option-add {
  width: 130rpx;
  height: 82rpx;
  border-radius: 24rpx;
  color: #fff;
  font-size: 26rpx;
  font-weight: 800;
  background: #2b221b;
}

.option-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.option-chip {
  padding: 14rpx 18rpx;
  border-radius: 999rpx;
  color: #7a4f26;
  font-size: 24rpx;
  background: #fff1d9;
}

.breath {
  display: flex;
  align-items: center;
  flex-direction: column;
}

.breath__circle {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 320rpx;
  height: 320rpx;
  margin: 34rpx 0;
  border-radius: 50%;
  background: radial-gradient(circle, #dff7ff 0%, #8ef6d1 55%, #60a5fa 100%);
  box-shadow: 0 28rpx 70rpx rgba(53, 143, 186, 0.24);
  transition: transform 1.2s ease, opacity 1.2s ease;
}

.breath__circle--run-0 {
  transform: scale(1.16);
}

.breath__circle--run-1 {
  transform: scale(1.16);
  opacity: 0.82;
}

.breath__circle--run-2 {
  transform: scale(0.82);
}

.breath__inner {
  color: #115e59;
  font-size: 44rpx;
  font-weight: 900;
}

.breath__tip {
  color: #4f6f67;
  font-size: 28rpx;
}

.breath__duration {
  margin: 12rpx 0 32rpx;
  color: #8c7765;
  font-size: 24rpx;
}

.dice {
  display: flex;
  align-items: center;
  flex-direction: column;
}

.dice__box {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 260rpx;
  height: 260rpx;
  margin: 42rpx 0;
  border-radius: 56rpx;
  color: #fff;
  font-size: 116rpx;
  font-weight: 900;
  background: linear-gradient(135deg, #f43f5e, #8b5cf6);
  box-shadow: 0 24rpx 58rpx rgba(137, 86, 214, 0.3);
}

.dice__box--rolling {
  transform: rotate(8deg) scale(1.04);
}

.dice__history-title {
  align-self: flex-start;
  margin-top: 36rpx;
}

.dice__history {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  width: 100%;
}

.dice__history-item {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 58rpx;
  height: 58rpx;
  border-radius: 18rpx;
  color: #8b3056;
  font-size: 26rpx;
  font-weight: 900;
  background: #ffe4ea;
}

.bubble__meta {
  margin-bottom: 24rpx;
  color: #4f6f67;
  font-size: 28rpx;
  font-weight: 900;
  text-align: center;
}

.bubble__grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 28rpx;
}

.bubble__item {
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  color: #0f766e;
  font-size: 20rpx;
  font-weight: 900;
  background: radial-gradient(circle at 35% 25%, #ffffff, #bae6fd 58%, #67e8f9);
  box-shadow: inset -8rpx -10rpx 16rpx rgba(14, 116, 144, 0.16), 0 10rpx 22rpx rgba(14, 116, 144, 0.12);
}

.bubble__item--popped {
  color: #9ca3af;
  background: #e5e7eb;
  box-shadow: inset 0 4rpx 10rpx rgba(107, 114, 128, 0.18);
}

.fortune {
  text-align: center;
}

.fortune__cookie {
  margin: 30rpx 0 20rpx;
  font-size: 128rpx;
}

.fortune__paper {
  margin: 0 0 34rpx;
  padding: 34rpx;
  border-radius: 30rpx;
  background: #fff7ea;
}

.fortune__level {
  color: #e2552d;
  font-size: 36rpx;
  font-weight: 900;
}

.fortune__text {
  margin-top: 18rpx;
  color: #6f5136;
  font-size: 30rpx;
  line-height: 1.7;
}

.fortune__placeholder {
  margin: 36rpx 0;
  color: #8c7765;
  font-size: 28rpx;
}
